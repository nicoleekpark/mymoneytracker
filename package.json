{
  "name": "hoh_finance-tracker",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npx expo start",
    "start:ios": "npx expo start --ios",
    "start:android": "npx expo start --android",
    "start:dev": "npx expo start -c --dev-client",
    "start:dev:ios": "npx expo start -c --dev-client --ios",
    "ios:run": "npx expo run:ios",
    "ios:uninstall": "dotenv -e .env.local -- sh -c 'xcrun simctl uninstall booted \"$EXPO_PUBLIC_IOS_BUNDLE_ID\" || true'",
    "ios:reset": "npm run ios:uninstall && expo prebuild --clean",
    "db:migration:new": "node scripts/create-migration.js",
    "db:migration:regen": "node scripts/create-migration.js --regen",
    "db:dev:pull": "./scripts/dbpull.sh",
    "db:reset": "./scripts/db-reset.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.8",
    "@tamagui/babel-plugin": "^1.142.0",
    "@tamagui/config": "^1.142.0",
    "expo": "~54.0.30",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "^1.142.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "better-sqlite3": "^12.10.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "jest-native": "^2.0.1",
    "prettier": "^3.2.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
